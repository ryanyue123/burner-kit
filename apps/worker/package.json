    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.0",
    "wrangler": "^4.80.0"
  }
}
